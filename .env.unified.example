# Unified environment for entire MetricFlow project.
# Copy this file to .env.unified and edit values once.

# Shared identifiers
NEXT_PUBLIC_APP_NAME=MetricFlow
METRICFLOW_API_KEY=mf_demo_key
DEFAULT_API_KEY=mf_demo_key
ANALYZER_API_KEY=mf_demo_key

# URLs
METRICFLOW_API_URL=http://localhost:4000
BACKEND_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:8000,http://localhost:3000
DASHBOARD_PORT=8000

# Backend
PORT=4000
MONGODB_URI=mongodb://localhost:27017/metricflow
JSON_BODY_LIMIT=256kb
MAX_ANALYZER_EVENTS=5000
EVENTS_TTL_DAYS=90

# Analyzer
ANALYZER_LOOKBACK_MINUTES=1440
ANALYZER_POLL_SECONDS=30
ANALYZER_RUN_ONCE=false
ANALYZER_REQUEST_TIMEOUT=20
