# MetricFlow Dashboard — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to source control.

# ─── API ───────────────────────────────────────────────────────────────────────
# Base URL of the MetricFlow Node.js backend (versioned — includes /v1).
# The dashboard's API service layer uses this as the prefix for all requests.
# In production, point this at your deployed backend or API gateway.
# Must match the shared contract in api.yml.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1

# ─── Optional: Auth (for future multi-tenant support) ─────────────────────────
# NEXT_PUBLIC_AUTH_DOMAIN=
# NEXT_PUBLIC_AUTH_CLIENT_ID=

# ─── Optional: Feature Flags ──────────────────────────────────────────────────
# Set to "true" to enable WebSocket real-time updates (future)
# NEXT_PUBLIC_ENABLE_REALTIME=false

# ─── Optional: Observability ──────────────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=
