{
  "name": "@metricflow/sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm,iife --dts --global-name MetricFlowSDK && node scripts/postbuild.mjs",
    "dev": "tsup src/index.ts --watch --format esm,iife --dts --global-name MetricFlowSDK",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.5.4"
  }
}
